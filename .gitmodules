[submodule "rtaudio"]
	path = rtaudio
	url = https://github.com/thestk/rtaudio.git
[submodule "ffmpeg"]
	path = ffmpeg
	url = https://github.com/FFmpeg/FFmpeg.git
	branch = release/6.0
[submodule "nv-codec-headers"]
	path = nv-codec-headers
	url = https://github.com/FFmpeg/nv-codec-headers.git
	branch = n12.0.16.1
[submodule "external/CPPMonetize"]
	path = external/CPPMonetize
	url = https://github.com/juliancoy/CPPMonetize.git
[submodule "external/ncnn"]
	path = external/ncnn
	url = https://github.com/juliancoy/ncnn.git
	branch = jcut/external-vulkan-device
[submodule "loiacono"]
	path = loiacono
	url = https://github.com/juliancoy/loiacono.git
[submodule "external/nlohmann_json"]
	path = external/nlohmann_json
	url = https://github.com/nlohmann/json
[submodule "external/imgui"]
	path = external/imgui
	url = https://github.com/ocornut/imgui
[submodule "external/rubberband"]
	path = external/rubberband
	url = https://github.com/breakfastquay/rubberband.git
