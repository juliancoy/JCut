#!/bin/bash
set -euo pipefail

app_dir="${APPDIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)}"

export LD_LIBRARY_PATH="${app_dir}/usr/lib${LD_LIBRARY_PATH:+:${LD_LIBRARY_PATH}}"
export QT_PLUGIN_PATH="${app_dir}/usr/plugins${QT_PLUGIN_PATH:+:${QT_PLUGIN_PATH}}"
export QT_QPA_PLATFORM_PLUGIN_PATH="${app_dir}/usr/plugins/platforms"
export XDG_DATA_DIRS="${app_dir}/usr/share:${XDG_DATA_DIRS:-/usr/local/share:/usr/share}"

exec "${app_dir}/usr/bin/jcut" "$@"
